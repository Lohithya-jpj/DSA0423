      "source": [
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Months of the year\n",
        "months = [\"Jan\", \"Feb\", \"Mar\", \"Apr\", \"May\", \"Jun\",\n",
        "          \"Jul\", \"Aug\", \"Sep\", \"Oct\", \"Nov\", \"Dec\"]\n",
        "\n",
        "# Monthly temperature data (in °C)\n",
        "temperature = [22, 24, 28, 32, 35, 33, 30, 29, 28, 26, 24, 23]\n",
        "\n",
        "# Monthly rainfall data (in mm)\n",
        "rainfall = [10, 20, 30, 40, 80, 120, 150, 140, 100, 60, 30, 15]\n",
        "\n",
        "# -------- Line Plot for Temperature --------\n",
        "plt.figure()\n",
        "plt.plot(months, temperature)\n",
        "plt.title(\"Monthly Temperature\")\n",
        "plt.xlabel(\"Months\")\n",
        "plt.ylabel(\"Temperature (°C)\")\n",
        "plt.show()\n",
        "\n",
        "# -------- Scatter Plot for Rainfall --------\n",
        "plt.figure()\n",
        "plt.scatter(months, rainfall)\n",
        "plt.title(\"Monthly Rainfall\")\n",
        "plt.xlabel(\"Months\")\n",
        "plt.ylabel(\"Rainfall (mm)\")\n",
        "plt.show()"
