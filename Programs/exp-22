import pandas as pd
from sklearn.tree import DecisionTreeClassifier
from sklearn.preprocessing import LabelEncoder

df = pd.DataFrame({
"age":[25,35,45,30],
"income":[30000,50000,70000,40000],
"browsing":[5,10,15,7],
"device":["mobile","desktop","mobile","tablet"],
"purchase":[0,1,1,0]
})

df["device"] = LabelEncoder().fit_transform(df["device"])

X = df[["age","income","browsing","device"]]
y = df["purchase"]

model = DecisionTreeClassifier().fit(X,y)

print(model.predict([[32,45000,8,1]]))
